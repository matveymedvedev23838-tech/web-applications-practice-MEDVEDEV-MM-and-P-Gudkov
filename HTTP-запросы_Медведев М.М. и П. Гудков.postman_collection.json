    {
      "name": "POST - Добавить продукт",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Статус 201 Created\", () => pm.response.to.have.status(201));\r",
              "const jsonData = pm.response.json();\r",
              "pm.test(\"ID нового продукта существует\", () => pm.expect(jsonData).to.have.property(\"id\"));\r",
              "pm.test(\"Название продукта совпадает\", () => pm.expect(jsonData.title).to.eql(\"Тестовый Смартфон X100\"));\r",
              "pm.collectionVariables.set(\"newProductId\", jsonData.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"title\": \"Тестовый Смартфон X100\",\r\n    \"price\": 49999\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/products/add",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "products",
            "add"
          ]
        }
      },
      "response": []
    },
    {
      "name": "PUT - Полное обновление продукта",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Статус 200 или 404\", () => {\r",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 404]);\r",
              "});\r",
              "if (pm.response.code === 200) {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.test(\"Цена обновлена\", () => pm.expect(jsonData.price).to.eql(69999));\r",
              "    pm.test(\"Название обновлено\", () => pm.expect(jsonData.title).to.eql(\"Обновленный Флагман X200\"));\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"title\": \"Обновленный Флагман X200\",\r\n    \"price\": 69999,\r\n    \"brand\": \"TestBrand\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/products/{{newProductId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "products",
            "{{newProductId}}"
          ]
        }
      },
      "response": []
    },
