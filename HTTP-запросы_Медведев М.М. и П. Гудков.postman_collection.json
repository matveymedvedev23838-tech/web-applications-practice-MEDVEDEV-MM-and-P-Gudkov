    {
      "name": "GET- Продукт по ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Статус 200\", () => pm.response.to.have.status(200));\r",
              "const jsonData = pm.response.json();\r",
              "pm.test(\"ID продукта = 1\", () => pm.expect(jsonData.id).to.eql(1));\r",
              "pm.test(\"Есть поле title (string)\", () => pm.expect(jsonData.title).to.be.a(\"string\"));\r",
              "pm.test(\"Есть поле price (number)\", () => pm.expect(jsonData.price).to.be.a(\"number\"));\r",
              "pm.test(\"Есть поле category\", () => pm.expect(jsonData).to.have.property(\"category\"));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cache-Control",
            "value": "no-cache",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/products/1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "products",
            "1"
          ]
        }
      },
      "response": []
