    {
      "name": "GET – Продукты с лимитом и skip (пагинация)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains 5 products\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.products).to.be.an('array').that.has.lengthOf(5);\r",
              "});\r",
              "\r",
              "pm.test(\"Skip parameter is correct\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.skip).to.eql(10);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [
          {
            "key": "Cache-Control",
            "value": "no-cache,no-store",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/products?limit=5&skip=10",
          "host": [
            "{{baseUrl}}"
          ],
